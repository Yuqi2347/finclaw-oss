# FinClaw LLM
FINCLAW_LLM_API_KEY=
FINCLAW_LLM_BASE_URL=https://api.openai.com/v1
FINCLAW_LLM_MODEL=gpt-4.1-mini
FINCLAW_LLM_TEMPERATURE=0.2
FINCLAW_LLM_TIMEOUT=120
FINCLAW_LLM_THINKING=disabled

# Web search / source citation
FINCLAW_WEB_SEARCH_ENABLED=true
FINCLAW_SEARCH_PROVIDER_ORDER=tavily,exa,brave
FINCLAW_WEB_SEARCH_MAX_SOURCES=4
FINCLAW_WEB_FETCH_TIMEOUT=5
FINCLAW_WEB_TOTAL_TIMEOUT=10
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
SERPER_API_KEY=
YOU_API_KEY=

# Local services
FINCLAW_API_BASE_URL=http://127.0.0.1:8800
FINCLAW_DATAHUB_MODE=embedded
FINCLAW_DATAHUB_MOUNT_PATH=/datahub
# Only used when FINCLAW_DATAHUB_MODE=http.
# DATAHUB_BASE_URL=http://127.0.0.1:8700
TRADINGGRAPH_WEB_BASE=http://127.0.0.1:5173
TRADINGGRAPH_WEB_AUTO_START=false
TRADINGGRAPH_WEB_START_TIMEOUT=15

# Market data providers
TUSHARE_TOKEN=
FINDATAHUB_PROVIDER_PROFILE=free
FINDATAHUB_DB_URL=sqlite:///./services/findatahub/data/findatahub.sqlite

# Capability roots
TRADINGAGENTS_ROOT=./capabilities/tradingagents_astock
# Optional separately installed capabilities. Enable their capability manifests
# after installing the corresponding implementation.
# BETTAFISH_ROOT=../BettaFish
# TRADINGGRAPH_ROOT=../TradingGraph

# Execution
FINCLAW_PYTHON=python
FINCLAW_RUN_LOCK_TTL_SECONDS=180
